rules_version = '2';

// Richy security rules.
// Each user can read and write ONLY their own document at users/{uid}.
// You (the project owner) can still see every user's data in the Firebase
// console regardless of these rules - the console bypasses them.
//
// HOW TO APPLY:
//   Firebase console -> Build -> Firestore Database -> Rules tab ->
//   paste this whole file -> Publish.

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Households (Collab / couples mode). A shared document that two or more
    // members read and write together. Private data is NEVER stored here - it
    // stays in each member's users/{uid} doc - so document-level read access is
    // safe to grant to every member.
    match /households/{hid} {
      function isMember() {
        return request.auth != null && request.auth.uid in resource.data.memberUids;
      }
      // An invited (but not yet joined) user is identified by their verified email
      // sitting in pendingEmails - this lets them see and accept the invite.
      function isInvited() {
        return request.auth != null
          && request.auth.token.email != null
          && request.auth.token.email in resource.data.pendingEmails;
      }
      // Create: only if the creator lists themselves as a member and as creator.
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.createdBy == request.auth.uid;
      // Read: members, or an invited email (so the invite is discoverable).
      allow read: if isMember() || isInvited();
      // Update: existing members, or an invited user accepting (adding self).
      allow update: if isMember() || isInvited();
      // Delete: only members (e.g. winding down the household).
      allow delete: if isMember();
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
